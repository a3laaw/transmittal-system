// Prisma schema for Nova EDMS (Site Secretary)
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id            String   @id @default(cuid())
  code          String   @unique
  // Short code used for internal reference sequencing (TR for TRANSMITTAL, MR for MIR, etc.)
  // NOT written in the Excel template — used only for backend uniqueness grouping
  shortCode     String?
  label         String
  labelEn       String?
  icon          String   @default("📄")
  color         String   @default("bg-blue-100 text-blue-700")
  templatePath  String?
  templateType  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  disciplines  Discipline[]
  disciplineCategories DisciplineCategory[]
  transmittals Transmittal[]
  docTypes     DocType[]
}

model DocType {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  labelEn   String?
  categoryCode String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category  Category? @relation(fields: [categoryCode], references: [code], onDelete: SetNull)
}

model Discipline {
  id         String   @id @default(cuid())
  code       String   @unique
  label      String
  labelEn    String?
  color      String
  prefix     String
  categoryCode String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category      Category?           @relation(fields: [categoryCode], references: [code], onDelete: Restrict)
  categories    DisciplineCategory[]
}

// Many-to-many: a discipline can belong to multiple categories
model DisciplineCategory {
  id            String   @id @default(cuid())
  disciplineId  String
  categoryCode  String
  createdAt     DateTime @default(now())

  discipline  Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  category    Category   @relation(fields: [categoryCode], references: [code], onDelete: Cascade)

  @@unique([disciplineId, categoryCode])
  @@index([disciplineId])
  @@index([categoryCode])
}

model Transmittal {
  id          String   @id @default(cuid())
  reference   String
  discipline  String
  disciplineCode String?
  category    String   @default("TRANSMITTAL")
  type        String?
  description String?
  alternativeTitle String?
  parentTransmittalId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryRef Category?   @relation(fields: [category], references: [code], onDelete: Restrict)
  parent      Transmittal? @relation("TransmittalLink", fields: [parentTransmittalId], references: [id], onDelete: SetNull)
  children    Transmittal[] @relation("TransmittalLink")
  revisions   Revision[]
  reviews     Review[]
  attachments Attachment[]

  @@index([discipline])
  @@index([disciplineCode])
  @@index([category])
  @@index([reference])
  @@index([parentTransmittalId])
  // Reference is unique PER CATEGORY, not globally.
  // This allows CIV-001 in TRANSMITTAL and CIV-001 in MIR to coexist.
  @@unique([category, reference])
}

model Revision {
  id            String   @id @default(cuid())
  transmittalId String
  revNumber     Int
  submitDate    DateTime?
  replyDate     DateTime?
  action        String?
  approvalType  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transmittal   Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)

  @@unique([transmittalId, revNumber])
  @@index([transmittalId])
}

model Review {
  id            String   @id @default(cuid())
  transmittalId String
  party         String
  status        String?
  submitDate    DateTime?
  submitRev     Int?
  reviewDate    DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transmittal   Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)

  @@unique([transmittalId, party])
  @@index([transmittalId])
}

model Attachment {
  id            String   @id @default(cuid())
  transmittalId String
  fileName      String
  filePath      String   @default("")
  fileType      String   @default("")
  fileSize      Int      @default(0)
  url           String?
  urlSource     String?
  createdAt     DateTime @default(now())

  transmittal   Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)

  @@index([transmittalId])
}
